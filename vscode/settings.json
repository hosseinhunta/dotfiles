{
    "workbench.colorTheme": "GitHub Light",
    "chat.mcp.gallery.enabled": true,
    "workbench.iconTheme": "material-icon-theme",
    "editor.fontFamily": "'JetBrains Mono', 'Fira Code', 'Cascadia Code', Consolas, 'Courier New', monospace",
    "terminal.integrated.fontFamily": "'CaskaydiaCove Nerd Font Mono', 'JetBrainsMono Nerd Font', 'FiraCode Nerd Font', Consolas, monospace",
    "terminal.integrated.fontSize": 14,
    "terminal.integrated.lineHeight": 1.2,
    "terminal.integrated.cursorStyle": "line",
    "terminal.integrated.cursorBlinking": true,
    "terminal.integrated.cursorWidth": 2,
    "terminal.integrated.enablePersistentSessions": true,
    "terminal.integrated.smoothScrolling": true,
    "terminal.integrated.scrollback": 10000,
    "terminal.integrated.rightClickBehavior": "paste",
    "workbench.colorCustomizations": {
        "panel.border": "#00000000",
        "terminal.border": "#80808020",
        "terminal.tab.activeBorder": "#ffffff"
    },
    "editor.fontLigatures": true,
    "editor.fontSize": 16,
    "editor.lineHeight": 1.7,
    "editor.fontWeight": "400",
    "editor.letterSpacing": 0.5,
    "editor.smoothScrolling": true,
    "workbench.list.smoothScrolling": true,
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.cursorBlinking": "expand",
    "editor.bracketPairColorization.enabled": true,
    "editor.guides.bracketPairs": "active",
    "editor.renderWhitespace": "boundary",
    // "editor.renderIndentGuides": true,
    "editor.rulers": [
        80,
        120
    ],
    "editor.minimap.enabled": false,
    "editor.occurrencesHighlight": "singleFile",
    "editor.selectionHighlight": true,
    "workbench.tree.indent": 20,
    "breadcrumbs.enabled": false,
    "editor.cursorWidth": 3,
    "editor.padding.top": 8,
    "editor.padding.bottom": 8,
    "editor.scrollbar.horizontal": "hidden",
    "editor.scrollbar.vertical": "auto",
    "editor.overviewRulerBorder": false,
    // "workbench.activityBar.location": "top",
    "workbench.enableExperiments": false,
    "editor.dragAndDrop": false,
    "workbench.editor.enablePreview": false,
    "editor.renderLineHighlight": "line",
    "editor.renderControlCharacters": false,
    "files.watcherExclude": {
        "**/.git/objects/**": true,
        "**/.git/subtree-cache/**": true,
        "**/node_modules/**": true,
        "**/.venv/**": true,
        "**/vendor/**": true,
        "**/__pycache__/**": true,
        "**/.next/**": true,
        "**/dist/**": true
    },
    "files.exclude": {
        "**/.git": true,
        "**/.DS_Store": true,
        "**/__pycache__": true,
        "**/.venv": true
    },
    "search.exclude": {
        "**/node_modules": true,
        "**/bower_components": true,
        "**/vendor": true,
        "**/.venv": true,
        "**/dist": true
    },
    "extensions.ignoreRecommendations": true,
    "workbench.editor.limit.enabled": true,
    "workbench.editor.limit.value": 5,
    "workbench.editor.limit.perEditorGroup": true,
    "editor.inlayHints.enabled": "offUnlessPressed",
    "editor.parameterHints.enabled": false,
    "editor.suggest.showStatusBar": false,
    "git.autofetch": false,
    "git.enabled": true,
    "extensions.autoUpdate": false,
    "update.mode": "none",
}